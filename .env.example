# compose.yaml reads this file. `scripts/up.sh` creates it on first run with
# sensible defaults — you shouldn't need to edit it unless you want to change
# which agents get installed.

HOST_UID=1000
HOST_GID=1000

# Which agent CLIs to bake into the image. AT LEAST ONE must be true — the
# Dockerfile fails fast with a [FATAL] message if both are false.
# If an install fails mid-build, the build fails with a [FATAL] message
# pointing at which flag to flip.
INSTALL_OPENCODE=true
INSTALL_CLAUDE=false

# paseo — multi-agent (claude/codex/opencode) daemon that pairs with
# desktop/mobile/web clients via QR code. Off by default. Independent of
# the agent CLIs above: paseo orchestrates whichever ones are installed.
# Enable both the build flag (here) and the runtime flag (PASEO_ENABLE
# below) to actually start the daemon. See PLAN.md §3.6.
INSTALL_PASEO=false

# bestiary — extensible MCP server (https://github.com/blackhat-7/bestiary).
# Off by default. BESTIARY_REF accepts a branch ("main"), tag ("v0.1.0"),
# or SHA. update.sh resolves branch/tag refs to a commit SHA at build time
# so docker's layer cache invalidates correctly when upstream moves —
# without that, "main" is a stale cache key forever. Pin to a tag for
# strict reproducibility; track "main" if you want each `update.sh` run
# to pick up upstream commits. See PLAN.md §3.5.
INSTALL_BESTIARY=false
BESTIARY_REF=main

# If you want the vivarium home somewhere other than ~/vivarium-home:
# VIVARIUM_HOME=/mnt/bigdisk/vivarium-home

# Optional: run `paseo daemon start --foreground --no-relay` from the
# container, paired by QR code from the paseo app on phone/desktop/web.
# Auth is the pairing crypto (NaCl box / XSalsa20-Poly1305) — no password
# to leak, but anyone who can scan the QR while it's on screen gets a key.
# So: only show the QR over trusted channels (`docker compose logs vivarium`).
#
# Tailscale-only setup (rootful Docker, e.g. on Hetzner): set
# PASEO_BIND_ADDR to this host's tailscale IPv4 (find it with
# `tailscale ip -4`). The container's :6767 then binds *only* to the
# tailscale interface — not LAN, not WAN. Phones / laptops on the same
# tailnet reach it directly; no host-side forwarder, no Caddy needed.
# `--no-relay` keeps the daemon from dialing paseo.sh's hosted relay,
# so traffic stays inside your tailnet.
#
# PASEO_HOSTNAMES is paseo's Host-header allowlist; the entrypoint
# defaults it to "true" (any host) because the network bind IS the
# auth gate. Tighten by listing exact hosts (comma-separated) if you
# want defense-in-depth.
# PASEO_ENABLE=false
# PASEO_BIND_ADDR=127.0.0.1     # set to your tailscale IP for tailnet-only
# PASEO_HOSTNAMES=

# NOTE: do NOT put per-project API secrets here. They'd persist into every
# session. Put them in ~/vivarium-home/.env.d/<project>.env and `source` them
# only when you start the session that needs them. See PLAN.md §5.
