# compose.yaml reads this file. `scripts/up.sh` creates it on first run with
# sensible defaults — you shouldn't need to edit it unless you want to change
# which agents get installed.

HOST_UID=1000
HOST_GID=1000

# Which agent CLIs to bake into the image. AT LEAST ONE must be true — the
# Dockerfile fails fast with a [FATAL] message if both are false.
# If an install fails mid-build, the build fails with a [FATAL] message
# pointing at which flag to flip.
INSTALL_OPENCODE=true
INSTALL_CLAUDE=false

# paseo — multi-agent (claude/codex/opencode) daemon that pairs with
# desktop/mobile/web clients via QR code. Off by default. Independent of
# the agent CLIs above: paseo orchestrates whichever ones are installed.
# Enable both the build flag (here) and the runtime flag (PASEO_ENABLE
# below) to actually start the daemon. See PLAN.md §3.6.
INSTALL_PASEO=false

# bestiary — extensible MCP server (https://github.com/blackhat-7/bestiary).
# Off by default. BESTIARY_REF accepts a branch ("main"), tag ("v0.1.0"),
# or SHA. update.sh resolves branch/tag refs to a commit SHA at build time
# so docker's layer cache invalidates correctly when upstream moves —
# without that, "main" is a stale cache key forever. Pin to a tag for
# strict reproducibility; track "main" if you want each `update.sh` run
# to pick up upstream commits. See PLAN.md §3.5.
INSTALL_BESTIARY=false
BESTIARY_REF=main

# If you want the vivarium home somewhere other than ~/vivarium-home:
# VIVARIUM_HOME=/mnt/bigdisk/vivarium-home

# Optional: expose `opencode web` from the container, gated by HTTP Basic auth.
# When set, the entrypoint runs `opencode web` instead of `sleep infinity`.
# Username is hardcoded by opencode as "opencode"; this is the password.
#
# Generate a strong one:  openssl rand -base64 32
# Leaked password = full agent control inside the container (file r/w in
# ~/vivarium-home, shell exec, OAuth-token / PAT exfil). Treat like an SSH key.
#
# The host port binding (compose.yaml `ports:`) defaults to 127.0.0.1 because
# Docker Desktop on Linux runs the daemon in a VM and cannot bind host-specific
# IPs. scripts/up.sh installs a systemd user unit (forwarder-install.sh) that
# bridges OPENCODE_FORWARD_ADDR:4096 -> OPENCODE_BIND_ADDR:4096 on the host, so
# only traffic arriving via headscale (e.g. from your Hetzner Caddy at
# opencode.immortal.cx) can reach it — not LAN, not WAN. With rootful Docker
# you can set both to 100.64.0.1 to skip the forwarder.
# OPENCODE_SERVER_PASSWORD=
# OPENCODE_BIND_ADDR=127.0.0.1
# OPENCODE_FORWARD_ADDR=100.64.0.1

# Optional: run `paseo daemon start` from the container, paired by QR code
# from the paseo app on phone/desktop/web. Auth is the pairing crypto
# (NaCl box / XSalsa20-Poly1305) — no password to leak, but anyone who can
# scan the QR while it's on screen gets a key. So: only show the QR over
# trusted channels (`docker compose logs vivarium`).
#
# Tailscale-only by default: container binds 6767 to 127.0.0.1, and
# scripts/forwarder-install-paseo.sh installs a systemd user unit that
# bridges PASEO_FORWARD_ADDR:6767 -> PASEO_BIND_ADDR:6767 on the host.
# Only traffic over headscale (laptop / phone with Tailscale up) can reach
# it — not LAN, not WAN. Paseo's relay is NOT used in this mode.
#
# PASEO_HOSTNAMES extends paseo's Host-header allowlist (defaults to
# "localhost,.localhost" upstream). The entrypoint auto-adds the
# PASEO_FORWARD_ADDR; add tailnet hostnames here if you connect by name.
# Comma-separated.
# PASEO_ENABLE=false
# PASEO_BIND_ADDR=127.0.0.1
# PASEO_FORWARD_ADDR=100.64.0.1
# PASEO_HOSTNAMES=

# NOTE: do NOT put per-project API secrets here. They'd persist into every
# session. Put them in ~/vivarium-home/.env.d/<project>.env and `source` them
# only when you start the session that needs them. See PLAN.md §5.
