{
  "$schema": "https://json.schemastore.org/claude-code-settings",
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "allowWrite": [
        "~/work",
        "~/.cache"
      ],
      "denyWrite": [
        "~/.ssh",
        "~/.claude",
        "~/.config",
        "~/.local/share",
        "~/.secrets",
        "~/.password-store",
        "~/.gnupg",
        "~/.bashrc",
        "~/.profile",
        "~/.zshrc",
        "~/.gitconfig",
        "~/.gitignore_global",
        "~/.npmrc",
        "~/.pypirc",
        "~/.cargo/config.toml",
        "/etc",
        "/usr",
        "/var",
        "/boot",
        "/root"
      ],
      "allowRead": [
        "~/work",
        "/usr",
        "/etc"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.secrets",
        "~/.password-store",
        "~/.gnupg"
      ]
    },
    "network": {
      "allowedDomains": [
        "api.anthropic.com",
        "code.claude.com",
        "docs.anthropic.com",
        "github.com",
        "*.githubusercontent.com",
        "codeload.github.com",
        "objects.githubusercontent.com",
        "raw.githubusercontent.com",
        "registry.npmjs.org",
        "pypi.org",
        "*.pythonhosted.org",
        "astral.sh",
        "crates.io",
        "static.crates.io",
        "index.crates.io",
        "proxy.golang.org",
        "sum.golang.org",
        "huggingface.co",
        "cdn-lfs.huggingface.co",
        "registry.ollama.ai"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Read",
      "Bash(git clone *)",
      "Bash(git pull *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git checkout *)"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(git remote*)",
      "Bash(git config*)",
      "Bash(gh *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(chmod 777 *)",
      "Bash(curl http*)",
      "Bash(wget *)",
      "WebFetch"
    ]
  }
}
