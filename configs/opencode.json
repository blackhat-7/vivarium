{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "allow",
    "bash": {
      "git push *": "deny",
      "git remote *": "deny",
      "git config *": "deny",
      "gh *": "deny",
      "ssh *": "deny",
      "scp *": "deny",
      "rsync *": "deny",
      "sudo *": "deny",
      "su *": "deny",
      "curl http*": "deny",
      "wget *": "deny",
      "chmod 777 *": "deny",
      "*": "allow"
    }
  }
}
